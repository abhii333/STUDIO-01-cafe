# ---- Backend (Render) environment ----
# Copy to .env for local dev and fill real values. NEVER commit real secrets.

# Flask
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET=change-me-to-a-different-long-random-string

# Database. Local dev falls back to SQLite if unset.
# On Render, paste your Neon pooled connection string (postgres:// is auto-normalized).
DATABASE_URL=sqlite:///cafe.db

# Seed admin (required in production; dev falls back to a warning + 'admin123')
ADMIN_PASSWORD=change-me
ADMIN_EMAIL=admin@studio01.com

# CORS: your Netlify site origin, e.g. https://your-cafe.netlify.app
FRONTEND_ORIGIN=*

# Set to 1 in production so the app initializes/seeds the DB on boot
AUTO_INIT_DB=0
PRODUCTION=0

# Razorpay (optional — payments disabled if unset). ROTATE any previously exposed keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret (Razorpay Dashboard > Settings > Webhooks). Enables POS UPI QR
# auto-confirmation. Point the webhook at: https://<your-backend>/api/webhooks/razorpay
# and subscribe to the "qr_code.credited" event.
RAZORPAY_WEBHOOK_SECRET=

# Cloudinary (optional — image upload disabled if unset)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Sentry (optional)
SENTRY_DSN=

# Email receipts (optional)
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@studio01.example
